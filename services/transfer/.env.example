# services/transfer/.env.example
#
# 이체(transfer) 서비스 로컬 실행용 환경변수 샘플.
# 사용 방법은 services/_template/.env.example 헤더 주석 참조.

# 이 서비스의 식별자 (로그/응답에 노출). 변경 금지.
SERVICE_NAME=transfer

# 이체 도메인 액션. POST /transfer 로 노출된다.
DOMAIN_ACTION=transfer

# Postgres 접속 문자열. 본 서비스 전용 DB (transfer_db).
DATABASE_URL=postgresql://payment:payment@localhost:5432/transfer_db

# DB 커넥션 풀.
DB_POOL_MIN=1
DB_POOL_MAX=5

# 로그 레벨.
LOG_LEVEL=INFO

# --- Task 1.3 에서 사용 (서비스 간 호출) ---
# 이체 처리 후 알림 서비스를 호출하기 위한 URL.
# 로컬:   http://localhost:8003 (notification 서비스의 로컬 포트)
# K8s:    http://notification.payment-dev.svc.cluster.local:8000
# Istio mesh 토폴로지 시연용 핵심 트래픽.
NOTIFICATION_URL=http://localhost:8003
