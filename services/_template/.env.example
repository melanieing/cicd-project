# services/_template/.env.example
#
# 본 파일은 서비스 1개를 로컬에서 실행할 때 필요한 환경변수의 샘플이다.
# 실제 사용 시:
#   1. 이 파일을 .env 로 복사 (`.gitignore`에 의해 .env 파일은 커밋되지 않음)
#   2. 값들을 환경에 맞게 수정
#   3. `export $(grep -v '^#' .env | xargs) && uvicorn main:app --reload`
# 컨테이너로 K8s에 배포될 때는 이 파일이 아닌 ConfigMap/Secret이 환경변수로 주입된다.

# 이 서비스의 식별자. 로그/메트릭 라벨/응답 본문에 사용된다.
# 4개 서비스 복제 시: account / transfer / loan / notification 으로 변경.
SERVICE_NAME=template

# 도메인 액션의 라우트 경로. 예: "open" -> POST /open 노출.
# main.py의 `f"/{DOMAIN_ACTION}"` 부분에서 동적으로 사용.
DOMAIN_ACTION=process

# PostgreSQL 접속 문자열.
# 형식: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# K8s 내부에서는 host가 보통 "postgres-svc.payment-dev.svc.cluster.local"
# 로컬 테스트 시에는 localhost.
DATABASE_URL=postgresql://payment:payment@localhost:5432/template_db

# DB 커넥션 풀 사이즈. pod 1개당 적용.
# HPA로 pod 수가 늘면 풀도 함께 확장된다.
DB_POOL_MIN=1
DB_POOL_MAX=5

# 로그 레벨. DEBUG / INFO / WARNING / ERROR / CRITICAL 중 선택.
LOG_LEVEL=INFO
