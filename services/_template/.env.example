# Copy to .env (gitignored) for local runs.
#
# In Kubernetes these are injected via ConfigMap/Secret in
# charts/payment-platform/templates/.

SERVICE_NAME=template
DOMAIN_ACTION=process

# Postgres connection. Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://payment:payment@localhost:5432/template_db

# Pool sizing (per-pod). HPA scales replicas; pool stays small per-pod.
DB_POOL_MIN=1
DB_POOL_MAX=5

LOG_LEVEL=INFO
