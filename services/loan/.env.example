# services/loan/.env.example
#
# 대출(loan) 서비스 로컬 실행용 환경변수 샘플.
# 사용 방법은 services/_template/.env.example 헤더 주석 참조.

# 이 서비스의 식별자 (로그/응답에 노출). 변경 금지.
SERVICE_NAME=loan

# 대출 신청 도메인 액션. POST /apply 로 노출된다.
DOMAIN_ACTION=apply

# Postgres 접속 문자열. 본 서비스 전용 DB (loan_db).
DATABASE_URL=postgresql://payment:payment@localhost:5432/loan_db

# DB 커넥션 풀.
DB_POOL_MIN=1
DB_POOL_MAX=5

# 로그 레벨.
LOG_LEVEL=INFO
