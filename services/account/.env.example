# services/account/.env.example
#
# 계좌(account) 서비스 로컬 실행용 환경변수 샘플.
# 사용 방법은 services/_template/.env.example 헤더 주석 참조.

# 이 서비스의 식별자 (로그/응답에 노출). 변경 금지.
SERVICE_NAME=account

# 계좌 개설 도메인 액션. POST /open 으로 노출된다.
DOMAIN_ACTION=open

# Postgres 접속 문자열. 본 서비스 전용 DB를 사용한다 (account_db).
# K8s 내부에서는 host가 "postgres-svc.payment-dev.svc.cluster.local".
DATABASE_URL=postgresql://payment:payment@localhost:5432/account_db

# DB 커넥션 풀. pod 1개당 적용.
DB_POOL_MIN=1
DB_POOL_MAX=5

# 로그 레벨.
LOG_LEVEL=INFO
